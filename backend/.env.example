PORT=8080
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:4200

# Optional durable fallback when Supabase is not configured.
# On Railway, mount a Volume and set this to a path inside it.
STATE_FILE_PATH=

# Supabase project settings.
# Use service role only on this backend. Never expose it to Angular/browser code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Optional: require a shared admin token for seed/admin endpoints later.
ADMIN_API_TOKEN=change-me
